# AgentBnB Managed Agents Adapter Configuration

# Registry URL (AgentBnB protocol registry endpoint)
REGISTRY_URL=https://agentbnb.fly.dev

# Managed Agents beta header (will change — never hardcode)
MANAGED_AGENTS_BETA_HEADER=managed-agents-2026-04-01

# Adapter HTTP port
ADAPTER_PORT=7702

# Ed25519 keystore path (persistent volume on Fly.io)
KEYSTORE_PATH=/data

# Maximum session cost in USD (billing guardrail)
MAX_SESSION_COST=5.00

# Service account owner name
SERVICE_ACCOUNT_OWNER=adapter-service-account
