{
  "name": "agentbnb",
  "version": "0.0.1",
  "description": "P2P Agent Capability Sharing Protocol — Airbnb for AI agent pipelines",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "agentbnb": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli/index.ts --format esm --dts",
    "dev": "tsx watch src/cli/index.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "agent",
    "capability",
    "sharing",
    "p2p",
    "protocol",
    "airbnb"
  ],
  "author": "Cheng Wen <樂洋集團>",
  "license": "MIT",
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.4.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "better-sqlite3": "^11.6.0",
    "bonjour-service": "^1.3.0",
    "commander": "^12.1.0",
    "fastify": "^5.1.0",
    "zod": "^3.24.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
