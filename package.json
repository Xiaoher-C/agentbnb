{
  "name": "agentbnb",
  "version": "3.1.5",
  "description": "P2P Agent Capability Sharing Protocol — Airbnb for AI agent pipelines",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "agentbnb": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./sdk": {
      "types": "./dist/sdk/index.d.ts",
      "import": "./dist/sdk/index.js"
    },
    "./identity": {
      "types": "./dist/identity/index.d.ts",
      "import": "./dist/identity/index.js"
    },
    "./adapters/claude-code": {
      "types": "./dist/adapters/claude-code/index.d.ts",
      "import": "./dist/adapters/claude-code/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "build:hub": "cd hub && pnpm install && pnpm build",
    "build:all": "pnpm build && pnpm build:hub",
    "dev": "tsx watch src/cli/index.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build && pnpm run typecheck && pnpm run test:run"
  },
  "keywords": [
    "ai",
    "agent",
    "capability",
    "sharing",
    "p2p",
    "protocol",
    "airbnb"
  ],
  "author": "Cheng Wen Chen",
  "license": "MIT",
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "eslint": "^9.0.0",
    "prettier": "^3.4.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.0.0",
    "@fastify/websocket": "^11.2.0",
    "better-sqlite3": "^11.6.0",
    "bonjour-service": "^1.3.0",
    "commander": "^12.1.0",
    "croner": "^10.0.1",
    "fastify": "^5.1.0",
    "js-yaml": "^4.1.1",
    "typed-emitter": "^2.1.0",
    "ws": "^8.19.0",
    "zod": "^3.24.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
